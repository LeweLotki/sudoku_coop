# Example environment configuration for the SudokuPad coop backend.
# Copy to `.env` and adjust as needed. These are placeholders for a future change;
# no settings are read by the current scaffold.

APP_NAME=sudoku-coop-api
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins (e.g. the extension origin).
ALLOWED_ORIGINS=http://localhost:5173

# Length of generated session codes (4-6 recommended).
SESSION_CODE_LENGTH=4
