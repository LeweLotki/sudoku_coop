# Example environment configuration for the SudokuPad coop backend.
# Copy to `.env` and adjust as needed. Do NOT commit your real `.env`.

APP_NAME=sudoku-coop-api
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins (HTTP surface only).
ALLOWED_ORIGINS=http://localhost:5173

# --- Security ---
# Invite-style access token required on every /ws connection (sent as ?token=...).
# In development this placeholder is fine; in production set a long random value
# via the Heroku config var. Never commit the real token.
ACCESS_TOKEN=change-me-local-dev-token

# Extra WebSocket Origins to allow beyond the chrome-extension:// scheme.
# Comma-separated. Web-page origins not listed here are rejected (CSWSH defense).
ALLOWED_WS_ORIGINS=

# --- Sessions ---
# Length of generated session codes (default 8).
SESSION_CODE_LENGTH=8
# Session time-to-live in seconds before lazy cleanup removes it (default 7200 = 2h).
SESSION_TTL_SECONDS=7200

# --- Limits (per-connection unless noted) ---
MAX_MESSAGES_PER_10_SECONDS=30
MAX_INVALID_MESSAGES_PER_CONNECTION=10
MAX_MESSAGE_BYTES=2048
MAX_ACTIVE_SESSIONS=50
MAX_GUESTS_PER_SESSION=5
