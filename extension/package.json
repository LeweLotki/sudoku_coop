{
  "name": "sudoku-coop-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Browser extension (MV3) for real-time SudokuPad coordination (scaffold only)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run build:popup && npm run build:background && npm run build:content && node scripts/postbuild.mjs",
    "build:popup": "vite build",
    "build:background": "BUILD_TARGET=background vite build",
    "build:content": "BUILD_TARGET=content vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
